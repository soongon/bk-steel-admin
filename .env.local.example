# =========================================================
# .env.local — 본인 머신에만 보관 (커밋 금지, .gitignore 처리됨)
#
# 복사:  cp .env.local.example .env.local  → 아래 빈 값 채우기
#
# 참고: 앱(브라우저·서버 컴포넌트·proxy)이 쓰는 NEXT_PUBLIC_SUPABASE_URL /
#       NEXT_PUBLIC_SUPABASE_ANON_KEY 는 커밋되는 .env.development 에 있다.
#       이 파일은 스크립트·서버 전용 시크릿만 담는다.
# =========================================================

# Supabase service role key (RLS 우회 — 시드/마이그레이션 스크립트 전용)
# 위치: Supabase Dashboard → Project Settings → Data API → service_role
# ⚠️ 절대 노출 금지 — 노출되면 RLS 무력화 가능
SUPABASE_SERVICE_ROLE_KEY=

# 스크립트(마이그레이션·레이더)용 Supabase URL.
# NEXT_PUBLIC_SUPABASE_URL 과 같은 값이지만, 스크립트는 NEXT_PUBLIC_* 을
# 못 읽으므로 이쪽에 별도로 둔다(의도된 중복).
SUPABASE_URL=https://qjbdtxwvgpldvdmmorcp.supabase.co

# 발주 레이더 — 공공데이터포털(data.go.kr) 인증키
# 건축HUB(건축인허가) 수집용. 위치: data.go.kr 마이페이지 → 인증키 발급
DATA_GO_KR_BUILDING_KEY=
# 나라장터(관급 입찰·낙찰) 수집용. 미설정 시 BUILDING_KEY 로 fallback.
DATA_GO_KR_NARA_KEY=

# 솔라피(CoolSMS) — 명세서 MMS(이미지) 전송. solapi.com 가입 후 발급.
# 발신번호(SOLAPI_SENDER)는 통신사 사전등록(사업자) 필수 — 숫자만.
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=

# 팝빌(Popbill) — 전자세금계산서 발행 ASP. popbill.com 연동신청 후 이메일로 LinkID/SecretKey 수령.
# 한 LinkHub 계정으로 법인(bk)·사업자(sl) 모두 발행(발행 사업자번호는 company_profile.business_no).
# POPBILL_IS_TEST=true → 테스트베드(국세청 실전송 없음). 운영전환(국세청 전송) 승인 후에만 false.
# 빈값이면 mock 어댑터로 동작(실발행·과금 없음).
POPBILL_LINK_ID=
POPBILL_SECRET_KEY=
POPBILL_IS_TEST=true

# 팝빌 메시지(문자 MMS + 카카오 알림톡) — 위 LinkHub 키 공유. 고객 메시징을 한 벤더로 통합.
# POPBILL_SENDER: 팝빌 등록 발신번호(숫자만). 미설정 시 명세서 MMS 는 솔라피로 fallback.
# 알림톡 템플릿코드: 팝빌 콘솔 승인 코드(발행안내/입금안내). 미설정 시 해당 알림톡 미발송.
# MESSAGE_PROVIDER=popbill|solapi|mock 강제(미설정 시 자동: 팝빌+발신번호→popbill, 아니면 솔라피→mock).
POPBILL_SENDER=
POPBILL_KAKAO_PLUSID=
POPBILL_ATS_TPL_INVOICE=
POPBILL_ATS_TPL_DUNNING=

# (선택) DB 직접 연결 — supabase db push 시 자동 사용되므로 보통 불필요
# DATABASE_URL=postgresql://postgres:[password]@db.qjbdtxwvgpldvdmmorcp.supabase.co:5432/postgres
